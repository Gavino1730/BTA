# BTA Production API Environment
# Copy these values into Railway for the `services/realtime-api` service.

NODE_ENV=production
PORT=4000
BTA_REQUIRE_TENANT=1
BTA_JWT_WRITE_REQUIRED=1

# Replace with your real frontend domains after Vercel deploys.
# Supports wildcard '*' for Vercel preview URLs, e.g.:
#   https://bta-coach-dashboard-*.vercel.app,https://bta-ipad-operator-*.vercel.app
ALLOWED_ORIGINS=https://btaintel.com,https://www.btaintel.com,https://dashboard.btaintel.com,https://operator.btaintel.com

# Supabase Postgres
# On Railway, prefer the Supabase Session/Connection Pooler (IPv4-compatible)
# URL instead of the direct `db.<project-ref>.supabase.co` host to avoid ENETUNREACH
# errors on platforms without outbound IPv6 support.
DATABASE_URL=postgresql://postgres:<password>@<project-ref>.pooler.supabase.com:6543/postgres

# Supabase JWT
BTA_JWT_ISSUER=https://<project-ref>.supabase.co/auth/v1
BTA_JWT_AUDIENCE=authenticated
BTA_JWT_JWKS_URI=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
BTA_JWT_SCHOOL_CLAIM=app_metadata.schoolId
BTA_JWT_ROLE_CLAIM=app_metadata.role

# Optional fallback if you need temporary API-key access during rollout
# BTA_API_KEY=replace-me

# Transactional email via Resend
RESEND_API_KEY=re_replace_me
BTA_EMAIL_FROM=BTA Courtside <no-reply@btaintel.com>
# Optional but recommended
# BTA_EMAIL_REPLY_TO=support@btaintel.com
BTA_COACH_APP_URL=https://dashboard.btaintel.com
# Optional internal routing copy for intake forms
# BTA_SUPPORT_INBOX=support@yourdomain.com
# Optional deletion grace period in days (minimum 1)
# BTA_ACCOUNT_DELETION_GRACE_DAYS=7

# Billing / paywall
# Keep disabled until Stripe test flow is verified end-to-end.
BTA_PAYWALL_ENABLED=0
BTA_BILLING_TRIAL_DAYS=14
# Stripe keys (use live keys only in production)
BTA_STRIPE_SECRET_KEY=sk_live_replace_me
BTA_STRIPE_WEBHOOK_SECRET=whsec_replace_me
BTA_STRIPE_PRICE_ID_MONTHLY=price_replace_monthly
BTA_STRIPE_PRICE_ID_YEARLY=price_replace_yearly

# Optional retention tuning
BTA_DATA_RETENTION_DAYS=180
BTA_RETENTION_PRUNE_INTERVAL_MINUTES=1440
