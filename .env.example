# ============================================================
# BTA Basketball Platform — Environment Variables
# Copy this file to .env and fill in any required values.
# ============================================================

# -------------------------------------------------------
# SERVICE PORTS (defaults work out of the box)
# -------------------------------------------------------
# Realtime API (Node/Express + Socket.io)
PORT=4000

# Video Worker (Node/Express)
VIDEO_PORT=4100

# Stats Dashboard (Flask)
# STATS_PORT=5000   # set inside services/stats-dashboard/.env

# iPad Operator UI runs on port 5174 (Vite, see vite.config.ts)
# Coach Dashboard UI runs on port 5173 (Vite, see vite.config.ts)

# -------------------------------------------------------
# STATS DASHBOARD (services/stats-dashboard/.env)
# -------------------------------------------------------
# Required for AI coaching tips and game analysis
# OPENAI_API_KEY=sk-...

# Optional: use PostgreSQL instead of local JSON files
# DATABASE_URL=postgresql://user:password@localhost:5432/bta_stats

# -------------------------------------------------------
# INTER-SERVICE URLs (used by the iPad operator app)
# These can be set as VITE_ env vars in apps/ipad-operator/.env
# -------------------------------------------------------
# Realtime API endpoint (default: http://localhost:4000)
# VITE_API=http://localhost:4000

# Stats dashboard endpoint shown as default in Game Setup
# (the operator can override this in-app per game)
# VITE_STATS_DASHBOARD=http://localhost:5000

# -------------------------------------------------------
# HOW TO START EVERYTHING
# -------------------------------------------------------
# 1. npm install                   (install Node deps)
# 2. npm run stats:install         (install Python deps)
# 3. npm run dev:all               (starts all 5 services at once)
#
# Individual services:
#   npm run dev:api        → Realtime API   at http://localhost:4000
#   npm run dev:operator   → iPad Operator  at http://localhost:5174
#   npm run dev:coach      → Coach Dashboard at http://localhost:5173
#   npm run dev:video      → Video Worker   at http://localhost:4100
#   npm run dev:stats      → Stats Dashboard at http://localhost:5000
