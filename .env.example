# ============================================================
# Basketball Platform — Environment Variables
# Copy this file to .env and fill in any required values.
# ============================================================

# -------------------------------------------------------
# SERVICE PORTS (defaults work out of the box)
# -------------------------------------------------------
# Realtime API (Node/Express + Socket.io)
PORT=4000

# Stats dashboard is served by realtime-api on PORT

# Operator Console UI runs on port 5174 (Vite, see vite.config.ts)
# Coach Dashboard UI runs on port 5173 (Vite, see vite.config.ts)

# -------------------------------------------------------
# STATS DASHBOARD
# -------------------------------------------------------
# Required for AI coaching tips and game analysis
# OPENAI_API_KEY=sk-...

# Optional: use PostgreSQL instead of local JSON files
# DATABASE_URL=postgresql://user:password@localhost:5432/stats
# BTA_REALTIME_DB_TABLE=bta

# Production hosting (recommended: Railway + Supabase + Vercel)
# NODE_ENV=production
# BTA_REQUIRE_TENANT=1
# BTA_JWT_WRITE_REQUIRED=1
# ALLOWED_ORIGINS=https://btaintel.com,https://www.btaintel.com,https://dashboard.btaintel.com,https://operator.btaintel.com

# Optional: managed JWT auth for realtime-api and future unified backend deploys
# Supabase examples:
# SUPABASE_URL=https://<your-project-ref>.supabase.co
# SUPABASE_PUBLISHABLE_KEY=<your-anon-or-publishable-key>
# SUPABASE_SERVICE_ROLE_KEY=<server-only-service-role-key>
# BTA_JWT_ISSUER=https://<your-project-ref>.supabase.co/auth/v1
# BTA_JWT_AUDIENCE=authenticated
# BTA_JWT_JWKS_URI=https://<your-project-ref>.supabase.co/auth/v1/.well-known/jwks.json
# BTA_JWT_SCHOOL_CLAIM=app_metadata.schoolId
# BTA_JWT_ROLE_CLAIM=app_metadata.role

# Transactional email (Resend)
# RESEND_API_KEY=re_...
# BTA_EMAIL_FROM=BTA Courtside <no-reply@btaintel.com>
# BTA_EMAIL_REPLY_TO=support@btaintel.com
# BTA_COACH_APP_URL=https://dashboard.btaintel.com
# BTA_SUPPORT_INBOX=support@yourdomain.com
# BTA_ACCOUNT_DELETION_GRACE_DAYS=7

# Billing / paywall (start in Stripe test mode)
# BTA_PAYWALL_ENABLED=1
# BTA_BILLING_TRIAL_DAYS=14
# BTA_STRIPE_SECRET_KEY=sk_test_...
# BTA_STRIPE_WEBHOOK_SECRET=whsec_...
# BTA_STRIPE_PRICE_ID_MONTHLY=price_...
# BTA_STRIPE_PRICE_ID_YEARLY=price_...

# Optional: school-scoped frontend defaults during transition to managed auth
# VITE_SCHOOL_ID=default

# -------------------------------------------------------
# INTER-SERVICE URLs (used by the operator app)
# These can be set as VITE_ env vars in the operator app .env file
# -------------------------------------------------------
# Realtime API endpoint (default: http://localhost:4000)
# VITE_API=http://localhost:4000

# Stats dashboard endpoint shown as default in Game Setup
# (the operator can override this in-app per game)
# VITE_STATS_DASHBOARD=http://localhost:4000

# -------------------------------------------------------
# HOW TO START EVERYTHING
# -------------------------------------------------------
# 1. npm install                   (install Node deps)
# 2. npm run dev:all               (starts API + 2 frontends)
#
# Individual apps/services:
#   npm run dev:api        → Realtime API   at http://localhost:4000
#   npm run dev:operator   → Operator Console at http://localhost:5174
#   npm run dev:coach      → Coach Dashboard at http://localhost:5173
#   npm run dev:stats      → Alias of dev:api (stats routes served by API)
