# Operator Console — Environment Variables
# Copy to .env.local and set values for your network.
# On localhost (dev): leave these blank, defaults work.
# On a local hotspot: set these to your laptop's LAN IP.
# On Vercel (prod): point these at your Railway + Vercel domains.

# Realtime API default URL (shown as placeholder in Game Setup settings)
# The operator can always override this in-app under Settings → Game Setup
VITE_API=http://localhost:4000
# VITE_API=https://api.btaintel.com

# Where the operator app opens the live coach view.
# VITE_COACH_DASHBOARD=https://dashboard.btaintel.com

# Supabase browser auth/session config.
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-anon-key>
# Optional compatibility names (also supported):
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-anon-key>

# Optional if you keep API-key mode enabled during rollout.
# VITE_API_KEY=replace-me

# Optional frontend default tenant/school scope.
# Recommended: leave unset and rely on auth/session or URL schoolId.
# VITE_SCHOOL_ID=your-school-id
