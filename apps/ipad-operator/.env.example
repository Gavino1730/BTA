# iPad Operator — Environment Variables
# Copy to .env.local and set values for your network.
# On localhost (dev): leave these blank, defaults work.
# On a local hotspot: set these to your laptop's LAN IP.

# Realtime API default URL (shown as placeholder in Game Setup settings)
# The operator can always override this in-app under Settings → Game Setup
VITE_API=http://localhost:4000
