# Vercel production env for iPad Operator
VITE_API=https://api.btaintel.com
VITE_COACH_DASHBOARD=https://www.btaintel.com
VITE_STATS_DASHBOARD=https://api.btaintel.com
# Supabase browser auth/session config
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-anon-key>
# Optional compatibility names (also supported):
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<supabase-publishable-anon-key>
# Optional frontend default tenant/school scope (recommended to keep unset and pass via auth/session).
# VITE_SCHOOL_ID=your-school-id

# Optional during API-key rollout only
# VITE_API_KEY=replace-me
