# Production env for Coach Dashboard when deploying separately from the API.
# When served from Railway (same origin as the API), VITE_API should NOT be set.
# Only set these if deploying the dashboard on a separate host (e.g. Vercel).
# VITE_API=https://api.yourdomain.com
# VITE_OPERATOR_CONSOLE=https://operator.yourdomain.com
VITE_SCHOOL_ID=default

# Optional during API-key rollout only
# VITE_API_KEY=replace-me
