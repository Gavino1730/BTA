{
  "name": "bta-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:api": "npm run dev -w @bta/realtime-api",
    "dev:coach": "npm run dev -w @bta/coach-dashboard",
    "dev:operator": "npm run dev -w @bta/ipad-operator",
    "dev:video": "npm run dev -w @bta/video-worker",
    "dev:stats": "cd services/stats-dashboard && .venv\\Scripts\\python main.py",
    "dev:all": "concurrently --names api,operator,coach,video,stats --prefix-colors cyan,green,yellow,magenta,blue \"npm run dev:api\" \"npm run dev:operator\" \"npm run dev:coach\" \"npm run dev:video\" \"npm run dev:stats\"",
    "game-day": "pwsh -File scripts/game-day.ps1",
    "smoke-test": "pwsh -File scripts/smoke-test.ps1",
    "audit:ui": "node scripts/ui-audit.mjs",
    "stats:install": "cd services/stats-dashboard && pip install -r requirements.txt"
  },
  "devDependencies": {
    "@types/node": "^22.15.19",
    "concurrently": "^9.2.1",
    "playwright": "^1.58.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
