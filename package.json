{
  "name": "pivot-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev:api": "npm run dev -w @pivot/realtime-api",
    "dev:coach": "npm run dev -w @pivot/coach-dashboard",
    "dev:operator": "npm run dev -w @pivot/ipad-operator",
    "dev:video": "npm run dev -w @pivot/video-worker",
    "audit:ui": "node scripts/ui-audit.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.19",
    "playwright": "^1.58.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
